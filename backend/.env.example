# ── Base de datos PostgreSQL ──
DB_USER=postgres
DB_PASSWORD=tu_contraseña_de_postgres
HOST=127.0.0.1
DATABASE=papepos
PORT=5432

# ── Servidor ──
SERVER_PORT=5000
CORS_ORIGIN=http://localhost:3000

# ── Autenticación (acceso a Productos) ──
# Puedes usar una de estas dos:
ACCESS_PASSWORD=admin
# O mejor, un hash bcrypt (más seguro):
# ACCESS_PASSWORD_HASH=$2b$10$...

# ── IA Asistente (opcional) ──
DEEPSEEK_API_KEY=tu_api_key_de_deepseek

# ── Producción (opcional) ──
# NODE_ENV=production
